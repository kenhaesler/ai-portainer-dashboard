{
  "name": "@dashboard/security",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Container security scanning, PCAP capture, Harbor vulnerability management, eBPF coverage",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./routes/index.js": {
      "import": "./dist/routes/index.js",
      "types": "./dist/routes/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dashboard/contracts": "*",
    "@dashboard/core": "*",
    "@dashboard/infrastructure": "*",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "p-limit": "^7.3.0",
    "redis": "^5.12.1",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
